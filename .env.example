# ════════════════════════════════════════════════════════
# MeetAI Environment Configuration
# Copy to .env and fill in your values
# ════════════════════════════════════════════════════════

# ── LLM Keys (at least one required for real AI answers) ─
ANTHROPIC_API_KEY=sk-ant-...         # Claude (recommended)
OPENAI_API_KEY=sk-...                # GPT-4o / GPT-4 Vision
GEMINI_API_KEY=AIza...               # Gemini 2.0 Flash

# ── Ollama (local LLM, no key needed) ─────────────────────
# Start ollama server: ollama serve
# Pull model: ollama pull llama3:8b
OLLAMA_API_BASE=http://localhost:11434

# ── Cloud transcription (optional, adds speaker diarization) ─
# DEEPGRAM_API_KEY=...
# ASSEMBLYAI_API_KEY=...

# ── Backend settings ──────────────────────────────────────
MEETAI_PORT=8765
MEETAI_HOST=127.0.0.1

# ── Whisper model size ────────────────────────────────────
# Options: tiny, base, small, medium, large-v3
# tiny  = 39MB,  fastest, lower accuracy
# base  = 74MB,  good balance  ← recommended
# small = 244MB, better accuracy
# large = 1.5GB, best accuracy (requires 6GB+ VRAM for GPU)
WHISPER_MODEL=base

# ── Context for AI suggestions ────────────────────────────
# Write your experience / role here. The AI will use this
# to personalize suggestions to sound like YOU.
MEETAI_CONTEXT=Senior software engineer with 8 years experience in Python, distributed systems, and cloud architecture (AWS/GCP). Led 12-person team. Strong in system design, Kafka, Kubernetes, and API design.
