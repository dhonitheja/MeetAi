# MeetAI / PersonaAI environment template
# Copy this file to `.env` and fill in values before running production workflows.

# -- CORE SECURITY -------------------------------------------------------------
# REQUIRED: Hardware-bound key component for profile encryption
# What: Machine-specific secret component used in PBKDF2/Fernet key derivation
# Get: Generate locally -> python -c "import uuid; print(uuid.uuid4().hex)"
PERSONA_MACHINE_ID=

# REQUIRED: User-specific salt for profile encryption
# What: User-specific secret component combined with PERSONA_MACHINE_ID
# Get: Generate locally -> python -c "import secrets; print(secrets.token_hex(16))"
PERSONA_USER_SALT=

# -- LLM PROVIDERS -------------------------------------------------------------
# REQUIRED: OpenAI API key for co-pilot and embeddings
# What: API credential for OpenAI-backed completions and features
# Get: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OPTIONAL: Anthropic Claude API key (fallback provider)
# What: API credential for Anthropic Claude models
# Get: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OPTIONAL: Google Gemini API key (primary LLM provider in current startup checks)
# What: API credential for Google Gemini models
# Get: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# -- MEETING BOT ---------------------------------------------------------------
# REQUIRED for meeting bot: Recall.ai API key
# What: Credential for bot spawn/status/leave operations
# Get: https://www.recall.ai/dashboard
RECALL_API_KEY=

# REQUIRED for meeting bot: Secret for HMAC webhook verification
# What: Shared secret used to verify Recall webhook signatures
# Get: Generate locally -> python -c "import secrets; print(secrets.token_hex(32))"
RECALL_WEBHOOK_SECRET=

# REQUIRED for meeting bot: Public URL for Recall.ai transcript callbacks
# What: Public base URL Recall.ai can reach for /meeting/webhook
# Get: Your deployed domain or local tunnel URL (for example ngrok)
RECALL_WEBHOOK_URL=

# -- BILLING -------------------------------------------------------------------
# REQUIRED for billing: Stripe secret key
# What: Stripe server-side API key
# Get: https://dashboard.stripe.com/apikeys (use sk_test_ in development)
STRIPE_SECRET_KEY=

# REQUIRED for billing: Stripe webhook signing secret
# What: Secret used to verify Stripe-Signature header
# Get: Stripe Dashboard -> Webhooks -> endpoint -> Signing secret
STRIPE_WEBHOOK_SECRET=

# REQUIRED for billing: Stripe Pro plan price ID
# What: Stripe recurring price ID for the Pro tier
# Get: Stripe Dashboard -> Products -> Price ID
STRIPE_PRO_PRICE_ID=price_

# REQUIRED for billing: Stripe Team plan price ID
# What: Stripe recurring price ID for the Team tier
# Get: Stripe Dashboard -> Products -> Price ID
STRIPE_TEAM_PRICE_ID=price_

# REQUIRED for billing redirects: App base URL
# What: URL used for Stripe checkout success/cancel and portal return
# Get: Your frontend public URL (local example below)
APP_BASE_URL=http://localhost:3000

# -- SERVER CONFIG -------------------------------------------------------------
# OPTIONAL: FastAPI server port (backend defaults to 8765 if not overridden)
# What: Port binding used by backend launcher/runtime
# Get: Choose a free local port
PORT=8765

# OPTIONAL: Log level (DEBUG, INFO, WARNING, ERROR)
# What: Backend logging verbosity
# Get: Choose based on environment (INFO recommended for normal use)
LOG_LEVEL=INFO

# -- ELECTRON ------------------------------------------------------------------
# REQUIRED for production signed Windows builds
# What: Path/base64 blob for Windows code-signing certificate (.pfx)
# Get: Purchase cert from DigiCert/Sectigo/EV provider and export as PFX
WIN_CSC_LINK=

# REQUIRED when WIN_CSC_LINK is set
# What: Password for the Windows code-signing certificate
# Get: Defined when creating/exporting your certificate
WIN_CSC_KEY_PASSWORD=

# -- API BASE (Electron renderer) ----------------------------------------------
# OPTIONAL: Backend API base consumed by Electron UI
# What: Base URL used by renderer requests
# Get: Set to deployed backend URL or local backend URL
API_BASE=http://localhost:8765

# -- OPTIONAL RUNTIME TUNING ---------------------------------------------------
# OPTIONAL: Default model route key used by backend completions
# What: One of your configured providers (for example ollama, gemini, claude, gpt4)
# Get: Pick the default model route for your deployment
MEETAI_DEFAULT_MODEL=ollama

# OPTIONAL: Default interview context injected into prompts
# What: Resume/background context for suggestion generation
# Get: Your own profile text
MEETAI_CONTEXT=

# OPTIONAL: Default job title used in prompt context
# What: Candidate role context for meeting/interview prompts
# Get: Your target role name
MEETAI_JOB_TITLE=

# OPTIONAL: Default company name used in prompt context
# What: Company context for meeting/interview prompts
# Get: Your target company name
MEETAI_COMPANY=

# OPTIONAL: Ollama API endpoint for local model serving
# What: Base URL for local Ollama-compatible API
# Get: Default local Ollama endpoint
OLLAMA_API_BASE=http://localhost:11434

# OPTIONAL: Ollama text model name
# What: Local model identifier used for non-vision completion
# Get: `ollama list` -> choose installed model
OLLAMA_MODEL=gemma3:1b

# OPTIONAL: Ollama vision model name
# What: Local model identifier used for screenshot/vision analysis
# Get: Pull a vision-capable model (for example llava)
OLLAMA_VISION_MODEL=

# OPTIONAL: Whisper model size for local transcription
# What: Whisper model tier (tiny, base, small, medium, large-v3)
# Get: Choose based on available CPU/GPU and latency budget
WHISPER_MODEL=base
